# Supabase (Dashboard -> Project -> Connect / API Keys)
# Preferred: publishable key. Legacy anon JWT also supported.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-sb_publishable-key
# Optional fallback for older setups:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-legacy-anon-jwt

# Server-only: required for owner portal account management (invite users).
# Dashboard -> Settings -> API -> service_role key (secret).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
CRON_SECRET=replace-with-a-long-random-secret

# ---------------------------------------------------------------------------
# Backups (see docs/BACKUP_RUNBOOK.md). These are NOT app runtime vars — they
# are GitHub Actions *secrets* used by .github/workflows/backup.yml, listed here
# only for reference:
#   SUPABASE_DB_URL   Direct/session Postgres URI incl. password (port 5432).
#   RCLONE_CONF_B64   base64 of rclone.conf with `gdrive` (Drive) + `supa` (S3) remotes.
# The local manual snapshot (scripts/backup-snapshot.mjs) reuses
# NEXT_PUBLIC_SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY above; no extra vars needed.
# ---------------------------------------------------------------------------
